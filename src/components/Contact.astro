---
import CopyIcon from "./icons/CopyIcon.astro";
import WhatsappIcon from "./icons/WhatsappIcon.astro";
import EmailIcon from "./icons/EmailIcon.astro";
import CopyAnimation from "./CopyAnimation.jsx";
---

<section
    id="contact"
    class="grid grid-cols-1 md:grid-cols-2 md:max-w-xl items-center justify-center w-full max-w-5xl mx-auto px-4 py-25 relative text-white"
>
    <div class="w-full max-w-5xl mx-auto pr-18 py-20 relative">
        <h2 class="text-5xl font-semibold text-white py-4">Contacto</h2>
        <p class="text-2xl text-[#D0D0D4] pb-4">
            Transformamos ideas en sitios web que <span
                class="font-bold text-[#00FFC4]">venden</span
            >.
        </p>

        <button
            id="copyEmail"
            class="group flex items-center gap-2 text-white text-xl hover:font-semibold hover:text-[#00FFC4] transition-all duration-300"
        >
            <EmailIcon class="w-8 h-8" />
            bunnyweb@gmail.com
            <span
                class="opacity-0 group-hover:opacity-100 transition-opacity duration-200"
            >
                <CopyIcon class="w-3 h-3" />
            </span>
        </button>
        <div id="toast" class="hidden">
            <CopyAnimation />
        </div>

        <a
            href="https://wa.me/8187097029"
            class="flex items-center gap-2 text-white text-xl hover:font-semibold hover:text-[#00FFC4] transition-all duration-300 mt-4"
        >
            <WhatsappIcon class="w-8 h-8" />
            +52 8187097029
        </a>
    </div>

    <div class="flex flex-col items-center justify-center gap-4">
        <input
            type="text"
            placeholder="Nombre"
            class="w-full max-w-xl border border-[#64656C] rounded-3xl p-3 focus:border-[#00FFC4] outline-none"
        />
        <input
            type="email"
            placeholder="Email"
            class="w-full max-w-xl border border-[#64656C] rounded-3xl p-3 focus:border-[#00FFC4] outline-none"
        />
        <input
            type="text"
            placeholder="Asunto"
            class="w-full max-w-xl border border-[#64656C] rounded-3xl p-6 focus:border-[#00FFC4] outline-none"
        />
        <textarea
            placeholder="Mensaje"
            class="w-full max-w-xl border border-[#64656C] rounded-3xl p-6 focus:border-[#00FFC4] outline-none"
        ></textarea>
        <button
            class="w-[200px] border border-white p-3 rounded-3xl hover:border-[#00FFC4] transition-all duration-300 hover:scale-105"
            >Enviar</button
        >
    </div>
</section>
<script is:inline>
    const copyButton = document.getElementById("copyEmail");
    const toast = document.getElementById("toast");

    copyButton.addEventListener("click", () => {
        navigator.clipboard.writeText("bunnyweb@gmail.com").then(() => {
            // Mostrar el toast
            toast.classList.remove("hidden");
            toast.classList.add("opacity-100");

            // Ocultarlo después de 2.5 segundos
            setTimeout(() => {
                toast.classList.add("opacity-0");
                setTimeout(() => toast.classList.add("hidden"), 500); // Espera transición
            }, 2500);
        });
    });
</script>
