---
// Hero estilo "producto": titular + CTAs + mockup de un proyecto real + barra de stack.
const stack = ["Astro", "React", "Next.js", "Tailwind", "WordPress", "Figma"];
---

<section
    id="hero"
    class="relative flex min-h-screen flex-col items-center overflow-hidden bg-[#0d0f19] px-6 pt-[12.5rem]"
>
    <!-- Fondo: portal de luz (con parallax) -->
    <div
        id="hero-bg"
        class="pointer-events-none absolute inset-x-0 -top-20 h-[880px] bg-cover bg-top bg-no-repeat will-change-transform"
        style="background-image: url('/images/hero-bg.webp'); -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent); mask-image: linear-gradient(to bottom, black 60%, transparent);"
        aria-hidden="true"
    >
    </div>
    <!-- Cover para bajar la luminosidad del portal -->
    <div
        class="pointer-events-none absolute inset-0 bg-[#0d0f19]/45"
        aria-hidden="true"
    >
    </div>

    <!-- Texto -->
    <div class="relative z-10 flex max-w-4xl flex-col items-center text-center">
        <span
            class="hero-anim inline-flex items-center gap-2 rounded-full border border-[#64656C]/60 bg-white/[0.03] py-1 pl-1 pr-3 text-sm text-[#D0D0D4]"
            style="animation-delay: 0ms"
        >
            <span
                class="rounded-full bg-[#00FFC4] px-2.5 py-0.5 text-xs font-semibold text-[#0d0f19]"
                >Nuevo</span
            >
            Cotización gratis en 24 h
        </span>

        <h1
            class="mt-5 flex flex-wrap items-baseline justify-center gap-x-[0.28em] gap-y-1 text-4xl font-light leading-[1.08] tracking-tight sm:text-5xl lg:text-[3.5rem]"
        >
            <span class="hero-word" style="animation-delay: 90ms">Sitios</span>
            <span class="hero-word" style="animation-delay: 180ms">web</span>
            <span class="hero-word" style="animation-delay: 270ms">que</span>
            <span class="hero-word accent" style="animation-delay: 360ms"
                >venden.</span
            >
        </h1>

        <p
            class="hero-anim mt-5 max-w-xl text-base text-[#9A9AA4] text-balance md:text-lg"
            style="animation-delay: 480ms"
        >
            Diseñamos y desarrollamos landing pages y tiendas en línea a medida:
            modernas, rápidas y pensadas para convertir.
        </p>

        <div
            class="hero-anim mt-8 flex flex-col items-center gap-3 sm:flex-row"
            style="animation-delay: 570ms"
        >
            <a
                href="#contact"
                class="group flex items-center justify-center gap-2 rounded-full bg-[#00FFC4] px-6 py-3 text-sm font-semibold text-[#0d0f19] transition-all duration-300 hover:bg-[#008D6C] hover:text-white hover:scale-105"
            >
                Cotiza ahora
                <span
                    class="transition-transform duration-300 group-hover:translate-x-1"
                    >→</span
                >
            </a>
            <a
                href="#about"
                class="rounded-full border border-[#64656C] px-6 py-3 text-sm font-semibold text-white transition-all duration-300 hover:border-[#00FFC4] hover:text-[#00FFC4]"
            >
                Ver proyectos
            </a>
        </div>
    </div>

    <!-- Mockup de proyecto en marco de navegador, cortado abajo -->
    <div
        class="hero-anim relative z-10 mt-12 w-full max-w-3xl"
        style="animation-delay: 660ms"
    >
        <div
            class="overflow-hidden rounded-2xl border border-white/10 bg-[#0d0f19] shadow-2xl shadow-black/50"
        >
            <!-- Barra del navegador -->
            <div
                class="flex items-center gap-2 border-b border-white/10 bg-white/[0.03] px-4 py-3"
            >
                <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
                <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
                <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
                <span
                    class="mx-auto hidden rounded-md bg-white/5 px-4 py-1 text-xs text-[#7B7C85] sm:block"
                    >prioritydental.netlify.app</span
                >
            </div>
            <!-- Captura (recortada arriba) -->
            <div class="max-h-[340px] overflow-hidden">
                <img
                    src="/images/proyecto1.webp"
                    alt="Proyecto PriorityDental por BunnyWeb"
                    class="w-full object-cover object-top"
                />
            </div>
        </div>
        <!-- Difuminado inferior hacia el fondo -->
        <div
            class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#0d0f19] to-transparent"
        >
        </div>
    </div>

    <!-- Barra de stack -->
    <div
        class="hero-anim relative z-10 mb-10 mt-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
        style="animation-delay: 750ms"
    >
        <span class="text-sm text-[#64656C]">Construido con</span>
        {
            stack.map((tech) => (
                <span class="text-sm font-medium text-[#9A9AA4]">{tech}</span>
            ))
        }
    </div>
</section>

<script is:inline>
    (() => {
        const el = document.getElementById("hero-bg");
        if (!el) return;
        // Respeta a quien prefiere menos movimiento
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
            return;

        let ticking = false;
        const update = () => {
            el.style.transform = `translate3d(0, ${window.scrollY * 0.3}px, 0)`;
            ticking = false;
        };
        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    requestAnimationFrame(update);
                    ticking = true;
                }
            },
            { passive: true },
        );
        update();
    })();
</script>

<style>
    @keyframes heroFadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
            filter: blur(6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
            filter: blur(0);
        }
    }

    .hero-anim {
        animation: heroFadeUp 0.7s ease-out both;
    }

    /* Cada palabra del titular entra por separado (split text con CSS) */
    .hero-word {
        display: inline-block;
        /* Degradado vertical blanco -> gris tenue, recortado al texto */
        background: linear-gradient(
            180deg,
            #ffffff 0%,
            #f0f0f3 38%,
            #8b8c97 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        animation: heroFadeUp 0.6s ease-out both;
    }

    /* Palabra de acento: verde de marca en vez del degradado */
    .hero-word.accent {
        background: none;
        -webkit-text-fill-color: #00ffc4;
        color: #00ffc4;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-anim,
        .hero-word {
            animation: none;
        }
    }
</style>
