---
import LandingIcon from "../components/icons/LandingIcon.astro";
import ShopIcon from "../components/icons/ShopIcon.astro";

const services = [
    {
        icon: LandingIcon,
        title: "Landing Page",
        tagline: "Una página que convierte visitantes en clientes.",
        features: [
            "Diseño moderno hecho a medida",
            "Optimizada para velocidad de carga",
            "Estructura enfocada en convertir",
            "Lista para tu próxima campaña",
        ],
        quote: "Landing Page",
    },
    {
        icon: ShopIcon,
        title: "E-commerce",
        tagline: "Tu tienda en línea, lista para vender desde el primer día.",
        features: [
            "Catálogo y carrito de compras",
            "Pasarelas de pago integradas",
            "Control de stock e inventario",
            "Panel de administración propio",
        ],
        quote: "E-commerce",
    },
];
---

<section
    id="services"
    aria-labelledby="services-title"
    class="w-full max-w-5xl mx-auto px-6 md:px-4 py-22 md:py-30"
>
    <div class="text-center">
        <h2 id="services-title" class="text-5xl font-semibold text-white">
            Servicios
        </h2>
        <p class="mt-3 text-xl text-[#9A9AA4]">
            Todo lo que necesitas para llevar tu <span class="text-[#00FFC4]"
                >negocio en línea</span
            >.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12 items-stretch">
        {
            services.map((service) => {
                const Icon = service.icon;
                return (
                    <div class="group flex h-full flex-col rounded-3xl border border-[#64656C]/60 bg-white/[0.02] p-7 transition-all duration-300 hover:-translate-y-2 hover:border-[#00FFC4]/50 hover:shadow-[0_20px_50px_-20px_rgba(0,255,196,0.25)]">
                        <div class="flex items-center gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-[#00FFC4]/25 bg-[#00FFC4]/10">
                                <Icon class="h-6 w-6" />
                            </div>
                            <h3 class="text-2xl font-semibold text-white">
                                {service.title}
                            </h3>
                        </div>

                        <p class="mt-5 text-lg text-[#D0D0D4]">
                            {service.tagline}
                        </p>

                        <ul class="mt-5 space-y-3">
                            {service.features.map((feature) => (
                                <li class="flex items-center gap-3 text-[#9A9AA4]">
                                    <span class="text-[#00FFC4]">✓</span>
                                    {feature}
                                </li>
                            ))}
                        </ul>

                        <a
                            href="#contact"
                            onclick={`window.selectPlan && window.selectPlan('${service.quote}')`}
                            class="group/link mt-auto inline-flex w-fit items-center gap-2 pt-7 font-medium text-[#00FFC4]"
                        >
                            Cotizar este servicio
                            <span class="transition-transform duration-300 group-hover/link:translate-x-1">
                                →
                            </span>
                        </a>
                    </div>
                );
            })
        }
    </div>
</section>
