---
import Logo from "../components/icons/Logo.astro";
---

<header class="justify-center items-center flex">
    <!-- Navbar -->
    <nav
        class="fixed top-0 z-50 w-full max-w-6xl flex justify-between items-center border border-[#64656C] backdrop-blur-sm rounded-3xl md:mx-8 mt-4 px-4 py-2"
    >
        <!-- Logo -->
        <div class="flex items-center">
            <a href="#hero">
                <Logo
                    alt="Logo"
                    class="w-32 h-10 md:w-40 md:h-12 hover:scale-105 transition-all duration-300"
                />
            </a>
        </div>

        <!-- Desktop Menu -->
        <div
            class="hidden md:flex items-center text-sm md:text-lg text-[#D0D0D4] gap-4 md:gap-6"
        >
            <a
                href="#hero"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Inicio</a
            >
            <a
                href="#services"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Servicios</a
            >
            <a
                href="#plans"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Planes</a
            >
            <a
                href="#about"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Sobre Nosotros</a
            >
            <a
                href="#contact"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Contacto</a
            >
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
            <button
                id="menu-toggle"
                aria-label="Abrir menú"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="text-[#D0D0D4] focus:outline-none hover:text-[#00FFC4] transition-all duration-300"
                onclick="const m=document.getElementById('mobile-menu');const closed=m.classList.toggle('hidden');this.setAttribute('aria-expanded', String(!closed));"
            >
                <!-- Icono de hamburguesa -->
                <svg
                    class="w-7 h-7"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Dropdown Menu -->
    <div
        id="mobile-menu"
        class="md:hidden fixed top-20 z-40 w-[60%] left-1/2 transform -translate-x-1/2 border border-[#64656C] backdrop-blur-md rounded-3xl p-4 hidden transition-all duration-300"
    >
        <ul class="flex flex-col text-[#D0D0D4] text-base gap-2">
            <li>
                <a
                    href="#hero"
                    onclick="document.getElementById('mobile-menu').classList.add('hidden')"
                    class="block py-2 px-4 rounded-xl hover:bg-[#00ffc40d] hover:text-[#00FFC4] transition-all duration-200"
                    >Inicio</a
                >
            </li>
            <li>
                <a
                    href="#services"
                    onclick="document.getElementById('mobile-menu').classList.add('hidden')"
                    class="block py-2 px-4 rounded-xl hover:bg-[#00ffc40d] hover:text-[#00FFC4] transition-all duration-200"
                    >Servicios</a
                >
            </li>
            <li>
                <a
                    href="#plans"
                    onclick="document.getElementById('mobile-menu').classList.add('hidden')"
                    class="block py-2 px-4 rounded-xl hover:bg-[#00ffc40d] hover:text-[#00FFC4] transition-all duration-200"
                    >Planes</a
                >
            </li>
            <li>
                <a
                    href="#about"
                    onclick="document.getElementById('mobile-menu').classList.add('hidden')"
                    class="block py-2 px-4 rounded-xl hover:bg-[#00ffc40d] hover:text-[#00FFC4] transition-all duration-200"
                    >Sobre Nosotros</a
                >
            </li>
            <li>
                <a
                    href="#contact"
                    onclick="document.getElementById('mobile-menu').classList.add('hidden')"
                    class="block py-2 px-4 rounded-xl hover:bg-[#00ffc40d] hover:text-[#00FFC4] transition-all duration-200"
                    >Contacto</a
                >
            </li>
        </ul>
    </div>
</header>
