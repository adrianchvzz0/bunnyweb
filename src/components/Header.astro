---
import Logo from "../components/icons/Logo.astro";
---

<header class="justify-center items-center flex">
    <!-- Navbar -->
    <nav
        id="navbar"
        class="fixed top-0 z-50 w-full max-w-[1700px] flex justify-between items-center rounded-3xl mt-4 px-6 md:px-10 py-3 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]"
    >
        <!-- Logo -->
        <div class="flex items-center">
            <a href="#hero">
                <Logo
                    alt="Logo"
                    class="w-32 h-10 md:w-40 md:h-12 hover:scale-105 transition-all duration-300"
                />
            </a>
        </div>

        <!-- Desktop Menu -->
        <div
            class="hidden md:flex items-center text-sm md:text-lg text-[#D0D0D4] gap-4 md:gap-6"
        >
            <a
                href="#hero"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Inicio</a
            >
            <a
                href="#services"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Servicios</a
            >
            <a
                href="#proyectos"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Proyectos</a
            >
            <a
                href="#plans"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Planes</a
            >
            <a
                href="#about"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Sobre Nosotros</a
            >
            <a
                href="#contact"
                class="hover:text-[#00FFC4] transition-all duration-300 hover:scale-105"
                >Contacto</a
            >
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
            <button
                id="menu-toggle"
                aria-label="Abrir menú"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="text-[#D0D0D4] focus:outline-none hover:text-[#00FFC4] transition-all duration-300"
                onclick="window.toggleMobileMenu()"
            >
                <!-- Icono de hamburguesa -->
                <svg
                    class="w-7 h-7"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Dropdown Menu -->
    <div
        id="mobile-menu"
        class="md:hidden fixed top-20 left-4 right-4 z-40 hidden rounded-3xl border border-white/10 bg-[#0d0f19]/95 p-3 shadow-2xl backdrop-blur-xl transition-all duration-300"
    >
        <ul class="flex flex-col gap-1">
            <li>
                <a
                    href="#hero"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Inicio</a
                >
            </li>
            <li>
                <a
                    href="#services"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Servicios</a
                >
            </li>
            <li>
                <a
                    href="#proyectos"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Proyectos</a
                >
            </li>
            <li>
                <a
                    href="#plans"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Planes</a
                >
            </li>
            <li>
                <a
                    href="#about"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Sobre Nosotros</a
                >
            </li>
            <li>
                <a
                    href="#contact"
                    onclick="window.closeMobileMenu()"
                    class="block rounded-xl px-4 py-3 text-lg text-[#D0D0D4] hover:bg-white/5 hover:text-[#00FFC4] transition-colors duration-200"
                    >Contacto</a
                >
            </li>
        </ul>
    </div>
</header>

<script is:inline>
    (() => {
        const nav = document.getElementById("navbar");
        if (nav) {
            const onScroll = () => {
                nav.classList.toggle("nav-scrolled", window.scrollY > 24);
            };
            window.addEventListener("scroll", onScroll, { passive: true });
            onScroll();
        }

        // Menú móvil con animación de apertura y cierre
        const menu = document.getElementById("mobile-menu");
        const btn = document.getElementById("menu-toggle");
        const reduce = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        let closeTimer;
        window.openMobileMenu = () => {
            if (!menu) return;
            clearTimeout(closeTimer);
            menu.classList.remove("hidden", "menu-closing");
            btn?.setAttribute("aria-expanded", "true");
        };
        window.closeMobileMenu = () => {
            if (!menu || menu.classList.contains("hidden")) return;
            btn?.setAttribute("aria-expanded", "false");
            if (reduce) {
                menu.classList.add("hidden");
                return;
            }
            menu.classList.add("menu-closing");
            clearTimeout(closeTimer);
            closeTimer = setTimeout(() => {
                menu.classList.add("hidden");
                menu.classList.remove("menu-closing");
            }, 220);
        };
        window.toggleMobileMenu = () => {
            if (!menu) return;
            menu.classList.contains("hidden")
                ? window.openMobileMenu()
                : window.closeMobileMenu();
        };
    })();
</script>

<style>
    /* Al hacer scroll: el contenido se recoge en la pill con vidrio esmerilado.
       Arriba va ancho (en las esquinas) y sin borde/blur. */
    #navbar.nav-scrolled {
        max-width: 72rem;
        padding: 0.5rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background-color: rgba(13, 15, 25, 0.3);
        -webkit-backdrop-filter: blur(16px) saturate(140%);
        backdrop-filter: blur(16px) saturate(140%);
    }

    /* Animación de apertura/cierre del menú móvil */
    @keyframes menuIn {
        from {
            opacity: 0;
            transform: translateY(-8px) scale(0.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    @keyframes menuOut {
        from {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        to {
            opacity: 0;
            transform: translateY(-8px) scale(0.98);
        }
    }
    #mobile-menu {
        transform-origin: top center;
    }
    #mobile-menu:not(.hidden):not(.menu-closing) {
        animation: menuIn 0.25s ease-out;
    }
    #mobile-menu.menu-closing {
        animation: menuOut 0.2s ease-in forwards;
    }
    @media (prefers-reduced-motion: reduce) {
        #mobile-menu:not(.hidden):not(.menu-closing) {
            animation: none;
        }
    }
</style>
