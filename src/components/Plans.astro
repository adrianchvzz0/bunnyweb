---
import PlanCard from "./PlanCard.astro";

const landingPlans = [
    {
        name: "Landing Básica",
        descriptor: "Ideal para presentar tu negocio.",
        price: "$2,999",
        popular: false,
        quote: "Landing Básica",
        features: [
            "1 página (hasta 5 secciones)",
            "Diseño personalizado",
            "Optimización móvil",
            "Formulario de contacto",
            "SEO básico",
        ],
    },
    {
        name: "Landing Premium",
        descriptor: "Para campañas y presencia completa.",
        price: "$6,000",
        popular: true,
        quote: "Landing Premium",
        features: [
            "Hasta 3 páginas",
            "Diseño personalizado premium",
            "Optimización móvil",
            "Integración con redes sociales",
            "SEO avanzado",
            "Estadísticas básicas",
        ],
    },
];

const ecommercePlans = [
    {
        name: "Tienda Básica",
        descriptor: "Empieza a vender en línea.",
        price: "$7,000",
        popular: false,
        quote: "Tienda Básica",
        features: [
            "Hasta 20 productos",
            "Diseño personalizado",
            "Carrito de compras",
            "1 método de pago",
            "Panel de administración",
        ],
    },
    {
        name: "Tienda Premium",
        descriptor: "Tienda completa, sin límites.",
        price: "$12,000",
        popular: true,
        quote: "Tienda Premium",
        features: [
            "Productos ilimitados",
            "Diseño personalizado premium",
            "Carrito avanzado",
            "Múltiples métodos de pago",
            "Panel de administración avanzado",
            "Integración con redes sociales",
            "SEO avanzado",
            "Estadísticas detalladas",
        ],
    },
];
---

<section
    id="plans"
    aria-labelledby="plans-title"
    class="w-full max-w-5xl mx-auto px-6 md:px-4 py-30"
>
    <div class="text-center">
        <h2 id="plans-title" class="text-5xl font-semibold text-white">Planes</h2>
        <p class="mt-3 text-xl text-[#9A9AA4]">
            El plan <span class="text-[#00FFC4]">perfecto</span> para ti. Todos incluyen
            personalización y cotización gratis.
        </p>
    </div>

    <!-- Control segmentado -->
    <div class="mt-10 flex justify-center">
        <div
            class="inline-flex rounded-full border border-[#64656C]/60 bg-white/[0.03] p-1"
            role="tablist"
        >
            <button
                type="button"
                data-plan="landing"
                aria-pressed="true"
                onclick="window.setPlanType('landing')"
                class="seg active rounded-full px-6 py-2 text-sm font-medium transition-colors"
            >
                Landing Page
            </button>
            <button
                type="button"
                data-plan="ecommerce"
                aria-pressed="false"
                onclick="window.setPlanType('ecommerce')"
                class="seg rounded-full px-6 py-2 text-sm font-medium transition-colors"
            >
                E-commerce
            </button>
        </div>
    </div>

    <!-- Planes Landing -->
    <div id="landing-plans" class="mt-14 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
            {landingPlans.map((plan) => <PlanCard {...plan} />)}
        </div>
    </div>

    <!-- Planes E-commerce -->
    <div id="ecommerce-plans" class="hidden mt-14 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
            {ecommercePlans.map((plan) => <PlanCard {...plan} />)}
        </div>
    </div>
</section>

<script is:inline>
    window.setPlanType = (type) => {
        const isLanding = type === "landing";
        const landing = document.getElementById("landing-plans");
        const ecommerce = document.getElementById("ecommerce-plans");
        const show = isLanding ? landing : ecommerce;
        const hide = isLanding ? ecommerce : landing;

        hide?.classList.add("hidden");
        if (show) {
            show.classList.remove("hidden", "plan-in");
            void show.offsetWidth; // reflow para reiniciar la animación
            show.classList.add("plan-in");
        }

        document.querySelectorAll(".seg").forEach((btn) => {
            const active = btn.dataset.plan === type;
            btn.classList.toggle("active", active);
            btn.setAttribute("aria-pressed", String(active));
        });
    };

    // Prefija el asunto del formulario al elegir un plan (lo usa también Servicios)
    window.selectPlan = (name) => {
        const subject = document.getElementById("subject");
        if (subject) subject.value = "Cotización: " + name;
    };

    document.addEventListener("DOMContentLoaded", () =>
        window.setPlanType("landing"),
    );
</script>

<style>
    .seg {
        color: #9a9aa4;
        cursor: pointer;
    }
    .seg.active {
        background-color: #00ffc4;
        color: #0d0f19;
    }

    /* Transición al cambiar entre Landing / E-commerce */
    @keyframes planFade {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .plan-in {
        animation: planFade 0.35s ease-out;
    }
    @media (prefers-reduced-motion: reduce) {
        .plan-in {
            animation: none;
        }
    }
</style>
