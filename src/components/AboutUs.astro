---
const projects = [
    {
        name: "PriorityDental",
        tag: "Clínica dental",
        url: "https://prioritydental.netlify.app",
        img: "/images/proyecto1.webp",
    },
    {
        name: "Ticketito",
        tag: "Venta de boletos",
        url: "https://ticketito.netlify.app",
        img: "/images/proyecto2.webp",
    },
    {
        name: "Nova",
        tag: "Asistente de voz",
        url: "https://hellonova.netlify.app",
        img: "/images/proyecto3.webp",
    },
    {
        name: "Rumbo",
        tag: "Marketing",
        url: "https://wearerumbo.com",
        img: "/images/proyecto4.webp",
    },
];
---

<div class="flex flex-col items-center justify-center gap-20">
    <div id="about" class="w-full max-w-5xl mx-auto px-4 py-20">
        <div class="flex items-center justify-center">
            <h2 class="text-5xl font-semibold text-white py-4">Nosotros</h2>
        </div>
        <p
            class="text-2xl text-[#D0D0D4] mb-10 text-center font-regular text-balance max-w-3xl mx-auto"
        >
            <span class="font-bold text-white text-2xl"
                >Somos BunnyWeb, donde la creatividad salta más alto.</span
            >
            <br />
            Nos apasiona construir espacios digitales que conecten, vendan y crezcan
            contigo. Ya sea que necesites una <span
                class="font-bold text-[#00FFC4]">landing page llamativa</span
            > o un <span class="font-bold text-[#00FFC4]"
                >e-commerce poderoso</span
            >, estamos aquí para hacerlo realidad con diseño moderno, buen gusto
            y un toque de magia digital.
        </p>
    </div>

    <div
        class="w-full flex flex-col items-center justify-center max-w-5xl mx-auto px-4 py-20"
    >
        <h2 class="text-5xl font-semibold text-white py-4">Proyectos</h2>
        <p class="text-lg text-[#9A9AA4] mb-12 text-center">
            Algunos de los sitios que hemos llevado a producción.
        </p>
        <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-6">
            {
                projects.map((project) => (
                    <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group relative block overflow-hidden rounded-2xl border border-white/10 transition-all duration-300 hover:border-[#00FFC4]/50 hover:shadow-[0_0_40px_-8px_rgba(0,255,196,0.35)]"
                    >
                        <img
                            src={project.img}
                            alt={`Proyecto ${project.name}`}
                            loading="lazy"
                            class="aspect-[16/10] w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                        />
                        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#0d0f19] via-[#0d0f19]/30 to-transparent opacity-85 transition-opacity duration-300 group-hover:opacity-95" />
                        <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 p-5">
                            <div>
                                <p class="text-xs font-medium uppercase tracking-[0.2em] text-[#00FFC4]">
                                    {project.tag}
                                </p>
                                <h3 class="mt-1 text-xl font-bold text-white">
                                    {project.name}
                                </h3>
                            </div>
                            <span class="translate-y-2 whitespace-nowrap rounded-full border border-white/20 bg-white/5 px-4 py-1.5 text-sm text-white opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                                Ver proyecto ↗
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</div>
